# ─────────────────────────────────────────────────────────────
# Network — Base Sepolia (real, verifiable testnet)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org

# Deployed contract addresses (fill in after `forge script script/Deploy.s.sol`)
NEXT_PUBLIC_DELEGATE_CORE_ADDRESS=
NEXT_PUBLIC_SUB_AGENT_REGISTRY_ADDRESS=
NEXT_PUBLIC_X402_VERIFIER_ADDRESS=
NEXT_PUBLIC_MOCK_USDC_ADDRESS=

# ─────────────────────────────────────────────────────────────
# Contract deployment (Foundry) — server-side only, never commit a real key
# ─────────────────────────────────────────────────────────────
# Deployer key used by `forge script` (funded with Base Sepolia ETH).
PRIVATE_KEY=
# Optional override addresses passed to the deploy script.
AGENT_ADDRESS=
ONESHOT_WALLET=
# For `forge verify` (optional).
BASESCAN_API_KEY=

# ─────────────────────────────────────────────────────────────
# Agent wallet (viem-direct fallback for real spends before 1Shot is configured)
# ─────────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=
# Where service micropayments are sent (defaults to the X402 verifier contract).
PAYMENT_SINK_ADDRESS=

# ─────────────────────────────────────────────────────────────
# 1Shot API (https://docs.1shotapi.com) — managed-wallet relayer
# ─────────────────────────────────────────────────────────────
ONESHOT_API_URL=https://api.1shotapi.com/v0
ONESHOT_API_KEY=
ONESHOT_API_SECRET=
ONESHOT_BUSINESS_ID=
# Configure a MockUSDC.transfer method endpoint in the 1Shot dashboard, paste its id:
ONESHOT_METHOD_TRANSFER=

# ─────────────────────────────────────────────────────────────
# Venice AI (Llama 3.3 70B) — planning + inference
# ─────────────────────────────────────────────────────────────
VENICE_API_KEY=

# ─────────────────────────────────────────────────────────────
# MetaMask / WalletConnect
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_METAMASK_PROJECT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_AGENT_SESSION_KEY=

# MetaMask Embedded Wallets (https://developer.metamask.io).
# When set, the app uses the unified Embedded Wallets modal (Google / X /
# Facebook / Email / Phone / MetaMask) and auto-faucets new wallets with a tiny
# amount of Base Sepolia ETH + test USDC. Leave empty to use the classic
# injected-MetaMask flow.
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=
# "devnet" (default) for Sapphire Devnet, "mainnet" for Sapphire Mainnet.
NEXT_PUBLIC_WEB3AUTH_NETWORK=devnet

# ─────────────────────────────────────────────────────────────
# Database — Neon Postgres (optional; in-memory store used if unset)
# DATABASE_URL = pooled connection (host has "-pooler"), used at runtime.
# DATABASE_DIRECT_URL = direct connection (host without "-pooler"), used for
# `prisma migrate`. Both come from the Neon dashboard → Connection Details.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=
DATABASE_DIRECT_URL=

# ─────────────────────────────────────────────────────────────
# WebSocket server
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:3001
WS_HTTP_URL=http://localhost:3001
WS_PORT=3001

# ─────────────────────────────────────────────────────────────
# Auth
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production

# Demo mode is OFF — this app runs against real on-chain state.
NEXT_PUBLIC_DEMO_MODE=false
